{
  "name": "llm-arena",
  "private": true,
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "concurrently -k \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w client",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
